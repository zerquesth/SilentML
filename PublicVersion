local function copyToBuffer(text)
	local success = false
	if setclipboard then
		setclipboard(text)
		success = true
	elseif toclipboard then
		toclipboard(text)
		success = true
	elseif Clipboard and Clipboard.set then
		Clipboard.set(text)
		success = true
	end
	return success
end

local function animateButton(button)
	local tweenInfo = TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local goal = {BackgroundColor3 = button.BackgroundColor3:Lerp(Color3.new(0,0,0), 0.2)}
	local tween = TweenService:Create(button, tweenInfo, goal)
	tween:Play()
	tween.Completed:Wait()
	local revert = {BackgroundColor3 = button.BackgroundColor3:Lerp(Color3.new(0,0,0), -0.2)}
	local revertTween = TweenService:Create(button, TweenInfo.new(0.1), revert)
	revertTween:Play()
end

local function setFeedback(text, color)
	feedbackLabel.Text = text
	feedbackLabel.TextColor3 = color
	local currentText = text
	task.delay(2, function()
		if feedbackLabel.Text == currentText then
			feedbackLabel.Text = ""
		end
	end)
end

local discordLink = "https://discord.gg/bQnXyAYTzF"
local cooldown = false

discordButton.MouseButton1Click:Connect(function()
	if cooldown then return end
	cooldown = true
	animateButton(discordButton)
	
	local copied = copyToBuffer(discordLink)
	if copied then
		setFeedback("Ссылка скопирована!", Color3.fromRGB(100, 200, 100))
	else
		setFeedback("Скопируйте вручную: " .. discordLink, Color3.fromRGB(255, 220, 100))
	end
	
	task.delay(1, function() cooldown = false end)
end)

